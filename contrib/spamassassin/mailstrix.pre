# Load the strixd SpamAssassin plugin.
#
# Copy this file into SpamAssassin's config dir (e.g. /etc/spamassassin/ or
# /etc/mail/spamassassin/) and point the path at wherever you installed
# Mailstrix.pm. The path is relative to the SpamAssassin site rules dir or absolute.
#
#   loadplugin Mail::SpamAssassin::Plugin::Mailstrix /etc/spamassassin/Mailstrix.pm
#
loadplugin Mail::SpamAssassin::Plugin::Mailstrix Mailstrix.pm
